{
  "name": "lattice-language",
  "displayName": "Lattice Language Support",
  "description": "Full language support for Lattice — syntax highlighting, completions, hover, go-to-definition, rename, formatting, and more via the clat-lsp language server",
  "version": "0.2.0",
  "publisher": "lattice-lang",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajokela/lattice"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "lattice",
    "lat",
    "crystallization",
    "phase",
    "immutable"
  ],
  "activationEvents": [
    "onLanguage:lattice"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lattice",
        "aliases": [
          "Lattice",
          "lattice"
        ],
        "extensions": [
          ".lat"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lattice",
        "scopeName": "source.lattice",
        "path": "./syntaxes/lattice.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Lattice",
      "properties": {
        "lattice.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Lattice language server (clat-lsp) for completions, diagnostics, hover, and more."
        },
        "lattice.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the clat-lsp binary. If empty, searches PATH."
        },
        "lattice.lsp.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the Lattice language server."
        }
      }
    },
    "commands": [
      {
        "command": "lattice.restartServer",
        "title": "Lattice: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
