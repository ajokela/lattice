export fn replace_solver(session: any, value: any) {
    let checked = _checked_solver(value)
    let state = _session_state(session)
    let current = state.experiment
    let next = _experiment_with(
    current,
    current.projectile,
    current.rifle,
    current.atmosphere,
    current.winds,
    current.shot,
    checked
    )
    _commit(session, _state(
    next,
    state.backend,
    state.display,
    state.history_limit,
    state.history,
    state.current_run,
    state.previous_run
    ))
}

export fn set_backend(session: any, value: any) {
    let checked = _checked_backend(value)
    let state = _session_state(session)
    _commit(session, _state(
    state.experiment,
    checked,
    state.display,
    state.history_limit,
    state.history,
    state.current_run,
    state.previous_run
    ))
}

export fn set_display_preferences(session: any, value: any) {
    let checked = _checked_display(value)
    let state = _session_state(session)
    _commit(session, _state(
    state.experiment,
    state.backend,
    checked,
    state.history_limit,
    state.history,
    state.current_run,
    state.previous_run
    ))
}

fn _trim_history(history: Array, limit: Int) -> Array {
    flux next = clone(history)
    while len(next) > limit {
        next.remove_at(0)
    }
    return next
}

export fn set_history_limit(session: any, value: any) {
    let checked = _history_limit(value)
    let state = _session_state(session)
    let next_history = _trim_history(state.history, checked)
    _commit(session, _state(
    state.experiment,
    state.backend,
    state.display,
    checked,
    next_history,
    state.current_run,
    state.previous_run
    ))
}

fn _record_or_error(backend: any, snapshot: any, result: any) -> any {
    if !_is_struct(result, "Trajectory") {
        return domain.laboratory_error(
        "backend_contract_error",
        "session solve expected Trajectory, got " + typeof(result)
        )
    }
    if result.experiment != snapshot {
        return domain.laboratory_error(
        "backend_contract_error",
        "backend trajectory does not retain the submitted experiment snapshot"
        )
    }
    if typeof(result.resolved_request) != "Map" {
        return domain.laboratory_error(
        "backend_contract_error",
        "backend trajectory must contain a resolved-request Map"
        )
    }
    return RunRecord {
        backend_name: backend.name,
        experiment: snapshot,
        result: result,
        resolved_request: result.resolved_request,
        schema_version: result.schema_version,
        engine_version: result.engine_version,
        assumptions: result.assumptions,
        warnings: result.warnings,
        termination: result.summary.termination
    }
}

export fn solve_session(session: any) -> any {
    let state = _session_state(session)
    // Experiment is already a frozen domain value, so this is an immutable O(1)
    // snapshot on shared-crystal runtimes and an independent immutable value on all VMs.
    let snapshot = state.experiment

    // Exactly one backend invocation. solve_with converts thrown/wrong-shape backends into
    // LaboratoryError values; every error path below returns before touching session state.
    let result = backends.solve_with(state.backend, snapshot)
    if backends.solve_failed(result) {
        return result
    }

    let record = _record_or_error(state.backend, snapshot, result)
    if _is_struct(record, "LaboratoryError") {
        return record
    }

    flux next_history = clone(state.history)
    if state.history_limit > 0 {
        next_history.push(record)
        while len(next_history) > state.history_limit {
            next_history.remove_at(0)
        }
    } else {
        next_history = []
    }
    let next_previous = state.current_run

    // Commit the complete next state once, after solve, provenance validation, record
    // construction, and history trimming have succeeded.
    _commit(session, _state(
    state.experiment,
    state.backend,
    state.display,
    state.history_limit,
    next_history,
    record,
    next_previous
    ))
    return record
}

// Reset run state while retaining the current experiment, backend configuration, display
// preferences, and configured history bound. The external engine remains stateless.
export fn reset_session(session: any) {
    let state = _session_state(session)
    _commit(session, _state(
    state.experiment,
    state.backend,
    state.display,
    state.history_limit,
    [],
    nil,
    nil
    ))
}
