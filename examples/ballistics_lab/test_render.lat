        fn test_profiles_and_validation() {
            let metric = render.metric_render_profile(3)
            let imperial = render.imperial_render_profile(1)
            assert(metric.distance_unit == "m")
            assert(metric.velocity_unit == "m/s")
            assert(metric.energy_unit == "J")
            assert(metric.precision == 3)
            assert(imperial.distance_unit == "yd")
            assert(imperial.velocity_unit == "ft/s")
            assert(imperial.energy_unit == "ft-lb")
            assert(render.offset_unit_for(metric) == "m")
            assert(render.offset_unit_for(imperial) == "in")
            assert(render.wind_speed_unit_for(metric) == "m/s")
            assert(render.wind_speed_unit_for(imperial) == "mph")
            assert(render.direction_unit_for(metric) == "deg")

            let copied = render.render_profile_from_display(
            sessions.display_preferences("ft", "m/s", "ft-lb", "moa", 4)
            )
            assert(copied.distance_unit == "ft")
            assert(copied.velocity_unit == "m/s")
            assert(copied.precision == 4)

            let profile_error = try {
                render.render_profile_from_display(42)
                "NO_ERROR"
            } catch error {
                error.message
            }
            assert_has(profile_error, "expected DisplayPreferences", "profile validation")
        }

        fn test_notice_and_error_snapshots() {
            let assumptions = render.render_assumptions([
                domain.assumption("alpha", "First | value.", "$.a"),
                domain.assumption("beta", "Second\nvalue.")
            ])
            assert(assumptions ==
            "Assumptions\n" +
            "  - alpha: First \\| value. [$.a]\n" +
            "  - beta: Second\\nvalue.",
            "assumption snapshot mismatch:\n" + assumptions)
            let warnings = render.render_warnings([])
            assert(warnings == "Warnings\n  none", "empty warning snapshot mismatch:\n" + warnings)

            let path_error = render.render_error(domain.laboratory_error(
            "bad_input",
            "Bad | input.\nTry again.",
            "$.shot",
            "engine stderr\nnext",
            7
            ))
            assert(path_error ==
            "Error\n" +
            "  code: bad_input\n" +
            "  message: Bad \\| input.\\nTry again.\n" +
            "  path: $.shot\n" +
            "  stderr: engine stderr\\nnext\n" +
            "  exit code: 7",
            "path error snapshot mismatch:\n" + path_error)

            let location_error = render.render_error(domain.laboratory_error(
            "command_syntax",
            "Unclosed quote.",
            nil,
            nil,
            nil,
            1,
            9
            ))
            assert(location_error ==
            "Error\n" +
            "  code: command_syntax\n" +
            "  message: Unclosed quote.\n" +
            "  location: 1:9",
            "location error snapshot mismatch:\n" + location_error)
        }

        fn test_fixed_fallback_and_flag_escaping() {
            let metric = render.metric_render_profile(2)
            let huge = parse_float("1e20")
            let huge_observation = domain.observation(
            units.m(0),
            huge,
            units.mps(huge),
            units.joules(huge),
            units.m(huge),
            units.m(0 - huge),
            huge,
            ["terminal"]
            )
            let huge_text = render.render_observation(huge_observation, metric)
            let huge_expected =
            "Observation\n" +
            "  distance: 0.00 m\n" +
            "  time    : 1e+20 s\n" +
            "  velocity: 1e+20 m/s\n" +
            "  energy  : 1e+20 J\n" +
            "  drop    : +1e+20 m\n" +
            "  windage : -1e+20 m\n" +
            "  Mach    : 1e+20\n" +
            "  flags   : terminal\n" +
            "Signs: drop/windage + above/right, - below/left"
            assert(huge_text == huge_expected, "huge finite fallback snapshot mismatch:\n" + huge_text)

            let escaped = Observation {
                distance: units.m(1),
                time_s: 0.1,
                velocity: units.mps(2),
                energy: units.joules(3),
                drop: units.m(0),
                windage: units.m(0),
                mach: 0.5,
                flags: ["terminal|next\nC:\\path"]
            }
            let escaped_text = render.render_observation(escaped, metric)
            let escaped_expected =
            "Observation\n" +
            "  distance: 1.00 m\n" +
            "  time    : 0.10 s\n" +
            "  velocity: 2.00 m/s\n" +
            "  energy  : 3.00 J\n" +
            "  drop    : +0.00 m\n" +
            "  windage : +0.00 m\n" +
            "  Mach    : 0.50\n" +
            "  flags   : terminal\\|next\\nC:\\\\path\n" +
            "Signs: drop/windage + above/right, - below/left"
            assert(escaped_text == escaped_expected,
            "observation flag escaping snapshot mismatch:\n" + escaped_text)
        }

        fn test_row_map_order_and_validation() {
            let lab = solved_session()
            let metric = render.metric_render_profile(2)
            let source = metric_dope(sessions.current_run(lab))
            flux reversed_rows = []
            for source_row in source.rows {
                let reversed = Map::new()
                flux index = len(source.columns) - 1
                while index >= 0 {
                    let column = source.columns[index]
                    reversed.set(column.key, source_row.get(column.key))
                    index = index - 1
                }
                reversed_rows.push(reversed)
            }
            let reordered = AnalysisTable {
                kind: source.kind,
                title: source.title,
                columns: source.columns,
                rows: reversed_rows,
                provenance: source.provenance
            }
            let reordered_text = render.render_dope(reordered, metric)
            assert(reordered_text == expected_dope_metric(),
            "row Map insertion order affected rendering:\n" + reordered_text)

            let unit_error = try {
                render.render_dope(source, render.imperial_render_profile(2))
                "NO_ERROR"
            } catch error {
                error.message
            }
            assert_has(unit_error, "expected 'yd', got 'm'", "profile/table unit mismatch")
            let kind_error = try {
                render.render_comparison(source, metric)
                "NO_ERROR"
            } catch error {
                error.message
            }
            assert_has(kind_error, "expected 'comparison', got 'dope'", "table kind validation")
            let error_type = try {
                render.render_error(42)
                "NO_ERROR"
            } catch error {
                error.message
            }
            assert_has(error_type, "expected LaboratoryError", "error renderer validation")
        }

        fn test_renderer_shapes_and_signs() {
            let lab = solved_session()
            let metric = render.metric_render_profile(2)
            let imperial = render.imperial_render_profile(2)
            let current = sessions.current_run(lab)

            let experiment_metric = render.render_experiment_summary(
            reference.representative_experiment(),
            metric
            )
            let experiment_imperial = render.render_experiment_summary(
            reference.representative_experiment(),
            imperial
            )
            assert(experiment_metric == expected_experiment_metric("175 gr match at 1,000 yards"),
            "metric experiment snapshot mismatch:\n" + experiment_metric)
            assert(experiment_imperial == expected_experiment_imperial(),
            "imperial experiment snapshot mismatch:\n" + experiment_imperial)

            let session_text = render.render_session_summary(lab)
            assert(session_text == expected_session(), "session snapshot mismatch:\n" + session_text)

            let run_text = render.render_run_summary(current, metric)
            assert(run_text == expected_run(), "run snapshot mismatch:\n" + run_text)
            let run_imperial = render.render_run_summary(current, imperial)
            assert(run_imperial == expected_run_imperial(),
            "imperial run snapshot mismatch:\n" + run_imperial)

            let at_zero = analysis.trajectory_at(current.result, units.m(0))
            let observation_text = render.render_observation(at_zero, metric)
            assert(observation_text == expected_observation(),
            "observation snapshot mismatch:\n" + observation_text)
            let observation_imperial = render.render_observation(at_zero, imperial)
            assert(observation_imperial == expected_observation_imperial(),
            "imperial observation snapshot mismatch:\n" + observation_imperial)

            let dope_metric = render.render_dope(metric_dope(current), metric)
            assert(dope_metric == expected_dope_metric(),
            "metric DOPE snapshot mismatch:\n" + dope_metric)
            let dope_imperial = render.render_dope(imperial_dope(current), imperial)
            assert(dope_imperial == expected_dope_imperial(),
            "imperial DOPE snapshot mismatch:\n" + dope_imperial)

            let wind = render.render_wind_card(metric_wind_card(current), metric)
            assert(wind == expected_wind(), "wind snapshot mismatch:\n" + wind)
            let wind_imperial = render.render_wind_card(imperial_wind_card(current), imperial)
            assert(wind_imperial == expected_wind_imperial(),
            "imperial wind snapshot mismatch:\n" + wind_imperial)

            let comparison = render.render_comparison(metric_comparison(lab), metric)
            assert(comparison == expected_comparison(),
            "comparison snapshot mismatch:\n" + comparison)
            let comparison_imperial = render.render_comparison(imperial_comparison(lab), imperial)
            assert(comparison_imperial == expected_comparison_imperial(),
            "imperial comparison snapshot mismatch:\n" + comparison_imperial)
        }

        fn dump_snapshots() {
            let lab = solved_session()
            let metric = render.metric_render_profile(2)
            let imperial = render.imperial_render_profile(2)
            let current = sessions.current_run(lab)
            print("===EXPERIMENT_METRIC===")
            print(render.render_experiment_summary(reference.representative_experiment(), metric))
            print("===EXPERIMENT_IMPERIAL===")
            print(render.render_experiment_summary(reference.representative_experiment(), imperial))
            print("===SESSION===")
            print(render.render_session_summary(lab))
            print("===RUN===")
            print(render.render_run_summary(current, metric))
            print("===RUN_IMPERIAL===")
            print(render.render_run_summary(current, imperial))
            print("===OBSERVATION===")
            print(render.render_observation(analysis.trajectory_at(current.result, units.m(0)), metric))
            print("===OBSERVATION_IMPERIAL===")
            print(render.render_observation(analysis.trajectory_at(current.result, units.m(0)), imperial))
            print("===DOPE_METRIC===")
            print(render.render_dope(metric_dope(current), metric))
            print("===DOPE_IMPERIAL===")
            print(render.render_dope(imperial_dope(current), imperial))
            print("===WIND===")
            print(render.render_wind_card(metric_wind_card(current), metric))
            print("===WIND_IMPERIAL===")
            print(render.render_wind_card(imperial_wind_card(current), imperial))
            print("===COMPARISON===")
            print(render.render_comparison(metric_comparison(lab), metric))
            print("===COMPARISON_IMPERIAL===")
            print(render.render_comparison(imperial_comparison(lab), imperial))
        }

        fn main() {
            if args().contains("dump") {
                dump_snapshots()
                return
            }
            test_profiles_and_validation()
            test_notice_and_error_snapshots()
            test_fixed_fallback_and_flag_escaping()
            test_renderer_shapes_and_signs()
            test_row_map_order_and_validation()
            print("ballistics_lab render: all tests passed")
        }
