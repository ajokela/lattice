// MBA-1311 deterministic terminal renderer tests.
// Run directly on StackVM, tree-walk, and RegVM.

import "examples/ballistics_lab/units" as units
import "examples/ballistics_lab/domain" as domain
import "examples/ballistics_lab/backend" as backends
import "examples/ballistics_lab/session" as sessions
import "examples/ballistics_lab/analysis" as analysis
import "examples/ballistics_lab/reference_experiment" as reference
import "examples/ballistics_lab/render" as render

// Struct-name validation is intentionally exercised without selectively
// importing exported struct types, which is not portable across all backends.
struct Observation {
    distance: fix any,
    time_s: fix Number,
    velocity: fix any,
    energy: fix any,
    drop: fix any,
    windage: fix any,
    mach: fix Number,
    flags: fix Array
}

struct AnalysisTable {
    kind: fix String,
    title: fix String,
    columns: fix Array,
    rows: fix Array,
    provenance: fix Array
}

fn named_experiment(name: String) -> any {
    let base = reference.representative_experiment()
    return domain.experiment(
    name,
    base.projectile,
    base.rifle,
    base.atmosphere,
    base.winds,
    base.shot,
    base.solver
    )
}

fn sample_observation(
distance_m: Number,
time_s: Number,
velocity_mps: Number,
energy_j: Number,
drop_m: Number,
windage_m: Number,
mach: Number,
terminal: Bool
) -> any {
    flux flags = []
    if terminal {
        flags = ["terminal"]
    }
    return domain.observation(
    units.m(distance_m),
    time_s,
    units.mps(velocity_mps),
    units.joules(energy_j),
    units.m(drop_m),
    units.m(windage_m),
    mach,
    flags
    )
}

fn trajectory_for(experiment: any, variant: Int) -> any {
    flux observations = []
    flux engine = "snapshot-engine-a"
    flux maximum_height = 1.25
    flux flight_time = 0.30
    flux terminal_velocity = 600.0
    flux terminal_energy = 2000.0
    flux spin_drift = -0.004
    if variant == 0 {
        observations = [
            sample_observation(0, 0, 800, 3000, -0.00004, 0.00004, 2.30, false),
            sample_observation(100, 0.14, 700, 2500, -0.12, -0.03, 2.05, false),
            sample_observation(200, 0.30, 600, 2000, -0.50, -0.08, 1.80, true)
        ]
    } else {
        engine = "snapshot-engine-b"
        maximum_height = 1.30
        flight_time = 0.31
        terminal_velocity = 610.0
        terminal_energy = 2050.0
        spin_drift = 0.003
        observations = [
            sample_observation(0, 0, 805, 3050, 0.00004, -0.00004, 2.31, false),
            sample_observation(150, 0.23, 660, 2300, -0.28, -0.045, 1.94, false),
            sample_observation(200, 0.31, 610, 2050, -0.45, -0.07, 1.82, true)
        ]
    }
    let request = Map::new()
    request.set("fixture", variant)
    let summary = domain.trajectory_summary(
    units.m(200),
    units.m(maximum_height),
    flight_time,
    units.mps(terminal_velocity),
    units.joules(terminal_energy),
    "velocity_floor",
    1.42,
    units.m(spin_drift)
    )
    return domain.trajectory(
    engine,
    experiment,
    observations,
    [domain.assumption(
        "model_default",
        "Used G7 | model.",
        "$.projectile.drag_model"
        )],
        [domain.warning(
            "range_notice",
            "Line one.\nLine two.",
            "$.shot.max_range"
            )],
            summary,
            variant == 1,
            request,
            1
            )
        }

        fn solved_session() -> any {
            let calls = Ref::new(0)
            let backend = backends.engine_backend("snapshot-backend", |experiment| {
                let variant = calls.get()
                calls.set(variant + 1)
                return trajectory_for(experiment, variant)
            }
            )
            let lab = sessions.new_session(
            named_experiment("snapshot experiment"),
            backend,
            render.metric_render_profile(2),
            4
            )
            let first = sessions.solve_session(lab)
            let second = sessions.solve_session(lab)
            assert(struct_name(first) == "RunRecord")
            assert(struct_name(second) == "RunRecord")
            return lab
        }

        fn metric_dope(run: any) -> any {
            return analysis.dope(
            run.result,
            [units.m(100), units.m(200)],
            "m",
            "mil",
            "m/s",
            "J"
            )
        }

        fn imperial_dope(run: any) -> any {
            return analysis.dope(
            run.result,
            [units.yd(100), units.yd(200)],
            "in",
            "mil",
            "ft/s",
            "ft-lb"
            )
        }

        fn metric_wind_card(run: any) -> any {
            return analysis.wind_card(
            [run.result],
            [units.m(100), units.m(200)],
            "m",
            "mil",
            "m/s",
            "deg"
            )
        }

        fn imperial_wind_card(run: any) -> any {
            return analysis.wind_card(
            [run.result],
            [units.yd(100), units.yd(200)],
            "in",
            "mil",
            "mph",
            "deg"
            )
        }

        fn metric_comparison(lab: any) -> any {
            return analysis.compare_trajectories(
            [sessions.previous_run(lab).result, sessions.current_run(lab).result],
            "m",
            "m",
            "m",
            "m/s",
            "J"
            )
        }

        fn imperial_comparison(lab: any) -> any {
            return analysis.compare_trajectories(
            [sessions.previous_run(lab).result, sessions.current_run(lab).result],
            "yd",
            "in",
            "in",
            "ft/s",
            "ft-lb"
            )
        }

        fn assert_has(actual: String, expected: String, label: String) {
            assert(actual.contains(expected), label + ": missing '" + expected + "' in:\n" + actual)
        }

