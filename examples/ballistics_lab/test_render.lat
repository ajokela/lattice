            return "  [" + to_string(index) + "] snapshot experiment\n" +
            "    engine: " + engine + " (schema 1)\n" +
            "    solver: rk45\n" +
            "    verified: " + verified + "\n" +
            "    termination: velocity_floor\n" +
            "    actual range: " + actual_range + "\n" +
            expected_notices("    ")
        }

