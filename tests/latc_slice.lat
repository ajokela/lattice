// LAT-444: single-level slice assignment through the self-hosted compiler.
// test-latc compares this program's output when compiled by latc.lat against a
// direct run by the C compiler. Nested slice-through-chain assignment
// (g[0][1..2] = v) is rejected at compile time by BOTH compilers and is checked
// separately by the test-latc compile-error section.

fn test_replace_same_length() {
    flux g = [1, 2, 3, 4]
    g[1..3] = [90, 91]
    print(g[0])
    print(g[1])
    print(g[2])
    print(g[3])
}

fn test_shrink() {
    flux g = [1, 2, 3, 4]
    g[0..2] = [7]
    print(g.len())
    print(g[0])
    print(g[1])
}

fn test_grow() {
    flux g = [1, 2, 3, 4]
    g[1..2] = [50, 51, 52]
    print(g.len())
    print(g[1])
    print(g[2])
    print(g[3])
}

fn test_local_slice() {
    flux a = [10, 20, 30, 40, 50]
    a[2..4] = [0]
    print(a.len())
    print(a[2])
    print(a[3])
}

fn main() {
    test_replace_same_length()
    test_shrink()
    test_grow()
    test_local_slice()
    print("ALL PASSED")
}
