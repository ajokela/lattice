// Test: scope/spawn round-trip through self-hosted compiler

// Test 1: Basic scope with spawns
// Spawned tasks run concurrently, so they must not print directly — they
// send results over a channel and the (sorted) output is printed after the
// scope joins, keeping the test output deterministic.
fn test_basic_scope() {
    print("--- basic scope ---")
    let ch = Channel::new()
    scope {
        spawn {
            ch.send(freeze("task A"))
        }
        spawn {
            ch.send(freeze("task B"))
        }
    }
    flux msgs = [ch.recv(), ch.recv()]
    let sorted = msgs.sort()
    print(sorted[0])
    print(sorted[1])
    print("after scope")
}

// Test 2: Scope with single spawn
fn test_single_spawn() {
    print("--- single spawn ---")
    scope {
        spawn {
            print("solo task")
        }
    }
    print("done")
}

// Test 3: Scope as expression
fn test_scope_expression() {
    print("--- scope expression ---")
    let r = scope {
        spawn {
            print("expr spawn")
        }
    }
    print("scope done")
}

// Test 4: Scope with sync body (non-spawn statements)
fn test_scope_with_sync() {
    print("--- scope with sync ---")
    scope {
        spawn {
            print("spawned work")
        }
    }
    print("sync after")
}

// Test 5: Multiple spawns (results sorted after join for determinism)
fn test_many_spawns() {
    print("--- many spawns ---")
    let ch = Channel::new()
    scope {
        spawn {
            ch.send(freeze("s1"))
        }
        spawn {
            ch.send(freeze("s2"))
        }
        spawn {
            ch.send(freeze("s3"))
        }
    }
    flux msgs = [ch.recv(), ch.recv(), ch.recv()]
    let sorted = msgs.sort()
    print(sorted[0])
    print(sorted[1])
    print(sorted[2])
    print("all spawns done")
}

// Test 6: Scope inside function (results sorted after join for determinism)
fn run_tasks() {
    let ch = Channel::new()
    scope {
        spawn {
            ch.send(freeze("fn spawn 1"))
        }
        spawn {
            ch.send(freeze("fn spawn 2"))
        }
    }
    flux msgs = [ch.recv(), ch.recv()]
    let sorted = msgs.sort()
    print(sorted[0])
    print(sorted[1])
}

fn test_scope_in_function() {
    print("--- scope in function ---")
    run_tasks()
    print("function returned")
}

// Test 7: Scope inside try
fn test_scope_in_try() {
    print("--- scope in try ---")
    try {
        scope {
            spawn {
                print("try spawn")
            }
        }
        print("try ok")
    } catch e {
        print("FAIL")
    }
}

fn main() {
    test_basic_scope()
    test_single_spawn()
    test_scope_expression()
    test_scope_with_sync()
    test_many_spawns()
    test_scope_in_function()
    test_scope_in_try()
    print("ALL SCOPE/SPAWN TESTS PASSED")
}
